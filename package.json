{
  "name": "md-to-pdf-cli",
  "version": "1.3.2",
  "description": "Convert Markdown files to styled PDF documents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "md-to-pdf-cli": "./dist/bin/md-to-pdf.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r src/styles dist/",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "katex": "^0.16.38",
    "marked": "^15.0.0",
    "marked-katex-extension": "^5.1.7",
    "prismjs": "^1.30.0",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/prismjs": "^1.26.6",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "markdown",
    "pdf",
    "markdown-to-pdf",
    "md-to-pdf",
    "converter",
    "cli",
    "puppeteer",
    "html-to-pdf",
    "syntax-highlighting",
    "prismjs",
    "katex",
    "math",
    "gfm",
    "document",
    "export"
  ],
  "license": "MIT"
}
